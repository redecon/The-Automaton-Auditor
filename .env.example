# Environment variables for The Automaton Auditor
# Copy this file to `.env` and fill in your own values
# Dependencies
# Installed via uv (see pyproject.toml)
# Required: PyPDF2 for PDF ingestion

# LangChain API key for tracing and LLM integration
LANGCHAIN_API_KEY=your_api_key_here

# Enable or disable LangChain tracing (true/false)
LANGCHAIN_TRACING_V2=true

# Optional: set logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Repo URL to audit (default can be overridden in code)
TARGET_REPO_URL=https://github.com/octocat/Hello-World

# Path to PDF report for analysis
TARGET_PDF_PATH=reports/Credit Risk Probability Model for Alternative Data.pdf
